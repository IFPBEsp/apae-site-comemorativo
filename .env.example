# =====================================================================
# .env — Stack integrado APAE (site-comemorativo + apae-geral + gestao-escolar)
# Valores de DESENVOLVIMENTO/LOCAL. Não use em produção.
# =====================================================================

# ---------- Comum ----------
JWT_SECRET=
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# ---------- Site Comemorativo ----------
DATABASE_URL_COMEMORATIVO=postgresql://postgres:postgres@db-comemorativo:5432/apae_comemorativo
BLOB_READ_WRITE_TOKEN_COMEMORATIVO=supersecrettoken
NEXT_PUBLIC_BASE_PATH=/site-comemorativo
POSTGRES_DB_COMEMORATIVO=apae_comemorativo
POSTGRES_USER_COMEMORATIVO=postgres
POSTGRES_PASSWORD_COMEMORATIVO=postgres

# ---------- APAE Geral ----------
POSTGRES_CONTAINER_APAE=apae-geral-db
POSTGRES_DB_APAE=apae
POSTGRES_USER_APAE=user
POSTGRES_PASSWORD_APAE=pass
POSTGRES_PORT_APAE=5200
POSTGRES_URL_APAE=jdbc:postgresql://db-apae-geral:5432/apae
API_PORT=8080
API_URL=http://apae-geral-backend:8080/apae-geral/api
MINIO_URL_APAE=http://minio:9000
CORS_ALLOWED_ORIGINS=http://localhost
APP_FRONTEND_RESET_PASSWORD_URL=http://localhost/apae-geral/auth/reset-password

# ---------- MinIO (compartilhado) ----------
MINIO_ROOT_USER_APAE=ROOTUSER
MINIO_ROOT_PASSWORD_APAE=CHANGEME123

# ---------- Gestão Escolar ----------
POSTGRES_DB_ESCOLAR=apae_escolar
POSTGRES_USER_ESCOLAR=postgres
POSTGRES_PASSWORD_ESCOLAR=postgres
# JDBC URL completa do backend (branch dev usa DATASOURCE_URL)
POSTGRES_URL_ESCOLAR=jdbc:postgresql://db-gestao-escolar:5432/apae_escolar
JWT_SECRET_ESCOLAR=
JWT_EXPIRATION_ESCOLAR=86400000
ADMIN_EMAIL=admin@apae.com.br
ADMIN_PASS=admin123
MINIO_BUCKET_ESCOLAR=apae-bucket
BACKEND_URL_ESCOLAR=http://gestao-escolar-backend:8080

NEXT_PUBLIC_URL_APAE=/apae-geral
NEXT_PUBLIC_URL_GESTAO_ESCOLAR=/gestao-escolar
