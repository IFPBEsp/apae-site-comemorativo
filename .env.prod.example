# =====================================================================
# .env.prod.example — variáveis de PRODUÇÃO (stack unificado)
# Copie e preencha:   cp .env.prod.example .env.prod
# NÃO commite o .env.prod. Gere segredos fortes (não reuse os de dev).
#   ex.: openssl rand -base64 32
# =====================================================================

# ---------- Imagens (GHCR) ----------
# owner da org no GHCR (minúsculo) e tag publicada pelo CI
IMAGE_OWNER=ifpbesp
IMAGE_TAG=latest

# ---------- URL pública ----------
# HTTP-first: http://<IP-DA-VM>   |   com domínio: https://seu-dominio
# Usada em CORS (apae-geral), reset de senha e MinIO público.
PUBLIC_URL=http://CHANGE_ME_IP_OU_DOMINIO

# ---------- Comum ----------
JWT_SECRET=CHANGE_ME_GERAR_SEGREDO_FORTE
MAIL_HOST=
MAIL_PORT=0

# ---------- Site Comemorativo ----------
DATABASE_URL_COMEMORATIVO=postgresql://comemorativo:CHANGE_ME_DB_PASS@db-comemorativo:5432/apae_comemorativo
BLOB_READ_WRITE_TOKEN_COMEMORATIVO=CHANGE_ME_TOKEN
NEXT_PUBLIC_BASE_PATH=/site-comemorativo
POSTGRES_DB_COMEMORATIVO=apae_comemorativo
POSTGRES_USER_COMEMORATIVO=comemorativo
POSTGRES_PASSWORD_COMEMORATIVO=CHANGE_ME_DB_PASS

# ---------- APAE Geral ----------
POSTGRES_DB_APAE=apae
POSTGRES_USER_APAE=apae
POSTGRES_PASSWORD_APAE=CHANGE_ME_DB_PASS
POSTGRES_URL_APAE=jdbc:postgresql://db-apae-geral:5432/apae
MINIO_URL_APAE=http://minio:9000

# ---------- MinIO (compartilhado) ----------
MINIO_ROOT_USER_APAE=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD_APAE=CHANGE_ME_MINIO_PASS

# ---------- Gestão Escolar ----------
POSTGRES_DB_ESCOLAR=apae_escolar
POSTGRES_USER_ESCOLAR=escolar
POSTGRES_PASSWORD_ESCOLAR=CHANGE_ME_DB_PASS
POSTGRES_URL_ESCOLAR=jdbc:postgresql://db-gestao-escolar:5432/apae_escolar
JWT_SECRET_ESCOLAR=CHANGE_ME_GERAR_SEGREDO_FORTE
JWT_EXPIRATION_ESCOLAR=86400000
# Admin "mestre" do gestão-escolar (login direto por env) — use senha forte!
ADMIN_EMAIL=admin@seu-dominio
ADMIN_PASS=CHANGE_ME_ADMIN_FORTE
MINIO_BUCKET_ESCOLAR=apae-bucket
